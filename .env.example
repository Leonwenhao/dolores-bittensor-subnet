# Path to a local checkout of the Dolores Autocurricula engine
# (task generation/verification). Required for the local demo and validator.
DOLORES_REPO=/path/to/dolores-autocurricula

# Never set DOLORES_ALLOW_EXTRINSICS in a file. It is one of the four
# explicit gates for live chain writes and must be set manually, per-run,
# in the shell that performs a supervised live submission.
