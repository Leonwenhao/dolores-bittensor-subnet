# Copy only into an operator-owned, mode-0600 environment file. Never commit a
# real value. Required by the validator; miners do not need this setting.
DOLORES_HOLDOUT_SECRET=

# Paid/provider-backed calibration remains off for the controlled cohort.
DOLORES_SUBNET_PANEL_MODE=mock
DOLORES_SUBNET_PANEL_DRYRUN=1

# Never set DOLORES_ALLOW_EXTRINSICS in a file. It is one of the four
# explicit gates for live chain writes and must be set manually, per-run,
# in the shell that performs a supervised live submission.
